# importar bibliotecas
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import folium

sns.set_theme(style="whitegrid")


# carregar dados
df = pd.read_csv("data/listings.csv")


# visão geral
print("Dimensão do dataset:", df.shape)

print("\nInformações:")
df.info()

print("\nPrimeiras linhas:")
print(df.head())

print("\nEstatísticas:")
print(df.describe())


# limpar dados
df.drop(columns=["neighbourhood_group", "license"], inplace=True)
df.dropna(subset=["price"], inplace=True)
df["reviews_per_month"].fillna(0, inplace=True)


# bairros com mais airbnbs
top_bairros = df["neighbourhood"].value_counts().head(10)


# gráfico bairros com mais imóveis
plt.figure(figsize=(10,6))

sns.barplot(
    x=top_bairros.values,
    y=top_bairros.index
)

plt.title("Bairros com mais Airbnbs no Rio de Janeiro")
plt.xlabel("Número de imóveis")
plt.ylabel("Bairro")

plt.tight_layout()
plt.show()


# remover preços extremos
df = df[df["price"] < 5000]


# preço médio por bairro
preco_bairro = df.groupby("neighbourhood")["price"].mean()
preco_bairro = preco_bairro.sort_values(ascending=False)

top_caros = preco_bairro.head(10)

print("\nBairros mais caros:")
print(top_caros)


# gráfico bairros mais caros
plt.figure(figsize=(10,6))

sns.barplot(
    x=top_caros.values,
    y=top_caros.index
)

plt.title("Bairros mais caros no Airbnb - Rio de Janeiro")
plt.xlabel("Preço médio da diária")
plt.ylabel("Bairro")

plt.tight_layout()
plt.show()


# ======================
# mapa de airbnbs
# ======================

mapa = folium.Map(
    location=[-22.9068, -43.1729],
    zoom_start=11
)

amostra = df.sample(1000)

for _, row in amostra.iterrows():

    folium.CircleMarker(
        location=[row["latitude"], row["longitude"]],
        radius=3,
        popup=f'Preço: {row["price"]}',
        color="blue",
        fill=True,
        fill_opacity=0.6
    ).add_to(mapa)

mapa.save("images/mapa_airbnb_rio.html")

mapa


# ======================
# preço por tipo de acomodação
# ======================

preco_tipo = df.groupby("room_type")["price"].mean().sort_values(ascending=False)

print("\nPreço médio por tipo de acomodação:")
print(preco_tipo)


plt.figure(figsize=(8,5))

sns.barplot(
    x=preco_tipo.index,
    y=preco_tipo.values
)

plt.title("Preço médio por tipo de acomodação")
plt.xlabel("Tipo de acomodação")
plt.ylabel("Preço médio da diária")

plt.tight_layout()
plt.show()



